# Root .env consumed by docker-compose.yml
# Generate a strong password — the previous default has been rotated.
POSTGRES_USER=getmcp
POSTGRES_PASSWORD=replace-with-a-strong-random-password
POSTGRES_DB=getmcp_platform

# Comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost,http://localhost:5173

VITE_API_URL=http://localhost:3000

# 32-byte AES-256-GCM key for encrypting per-org upstream secrets at rest.
# Generate: openssl rand -hex 32
KEY_ENCRYPTION_KEY=replace-with-64-hex-chars-from-openssl-rand-hex-32
