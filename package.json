{
  "name": "getmcp-monorepo",
  "version": "0.1.0",
  "description": "GetMCP — Zero Trust for AI agents. Generates and protects MCP servers.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Rayenbabdallah/GetMCP",
  "repository": { "type": "git", "url": "https://github.com/Rayenbabdallah/GetMCP.git" },
  "bugs": { "url": "https://github.com/Rayenbabdallah/GetMCP/issues" },
  "keywords": ["mcp", "model-context-protocol", "ai-agents", "zero-trust", "api-gateway", "audit-log", "self-hosted"],
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter api run start:dev",
    "dev:web": "pnpm --filter web run dev",
    "dev": "pnpm run dev:api & pnpm run dev:web",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
