# Postgres connection. Compose maps the DB to host port 5433.
DATABASE_URL="postgresql://getmcp:CHANGE_ME@localhost:5433/getmcp_platform?schema=public"

# API
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins. Use * only in dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Body size limit for JSON payloads (bytes)
JSON_BODY_LIMIT=1048576
