generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enterprise Organizations
model Organization {
  id        String   @id @default(cuid())
  name      String
  authType  String   // "Okta", "Auth0", "Custom"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Downstream API configuration. The proxy forwards agent requests to
  // upstreamBaseUrl + req.path, optionally injecting upstreamAuthHeader.
  upstreamBaseUrl    String?
  upstreamAuthHeader String?  // AES-256-GCM ciphertext, see src/crypto.util.ts
  upstreamTimeoutMs  Int      @default(30000)

  // Audit chain head. Updated atomically with each AuditLog write.
  lastAuditHash      String   @default("genesis")
  lastAuditSeq       Int      @default(0)

  // Slack integration for MUTATION_APPROVAL flow. All encrypted at rest.
  // Configure via PATCH /orgs/me.
  slackBotToken       String?
  slackSigningSecret  String?
  slackDefaultChannel String?

  specs                   OpenApiSpec[]
  policies                PolicyRule[]
  agents                  AgentIdentity[]
  apiKeys                 ApiKey[]
  auditLogs               AuditLog[]
  pendingRequests         PendingRequest[]
  endpointClassifications EndpointClassification[]
}

// Per-endpoint risk classification — produced by the LLM classifier (or the
// heuristic fallback) for a specific OpenAPI spec. Cached by spec hash so we
// never reclassify the same spec twice. Human overrides flip the verdict
// without re-running the classifier.
model EndpointClassification {
  id                       String       @id @default(cuid())
  organizationId           String
  specHash                 String       // sha256 of the canonical spec body
  path                     String
  method                   String
  dataSensitivity          Int          // 0-100 (higher = more risky)
  mutationImpact           Int          // 0-100
  hasTenantScope           Boolean
  reversible               Boolean
  exposeExternally         Boolean      // classifier verdict
  reasoning                String       // model's stated reason, audit-quality
  classifierSource         String       // "llm" | "heuristic"
  overrideExposeExternally Boolean?     // human override (null = use classifier)
  overrideBy               String?      // apiKeyId of the operator who set it
  overrideAt               DateTime?
  overrideReason           String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, specHash, path, method])
  @@index([organizationId, specHash])
}

// A held request awaiting human approval via Slack (or another channel).
// Created when a MUTATION_APPROVAL rule fires. On approval, the original
// request is replayed through the proxy with bypassApproval=true and the
// upstream response is captured here for the original caller to poll.
model PendingRequest {
  id                    String       @id @default(cuid())
  organizationId        String
  agentId               String?
  apiKeyId              String?
  method                String
  path                  String
  query                 Json?
  body                  Json?
  source                String
  tenantId              String?
  reasoning             String?
  ruleId                String       // policy rule that triggered the hold
  ruleName              String
  channel               String?      // Slack channel the approval was sent to
  slackMessageTs        String?      // Slack message timestamp, for chat.update
  status                String       @default("PENDING") // PENDING | APPROVED | DENIED | EXPIRED
  approverSlackUserId   String?
  approverSlackUserName String?
  decisionReason        String?
  decidedAt             DateTime?
  // Captured upstream response (JSON only, capped at 256KB). For non-JSON
  // bodies we store a base64 string; truncated payloads end with "[truncated]".
  responseStatus        Int?
  responseHeaders       Json?
  responseBody          Json?
  createdAt             DateTime     @default(now())
  expiresAt             DateTime

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvals             PendingRequestApproval[]

  @@index([organizationId, status])
  @@index([expiresAt])
}

// One row per approver vote on a pending request. Enables quorum (N-of-M approvers
// required before the held request replays) and captures per-vote justification text
// for the audit trail.
model PendingRequestApproval {
  id                    String         @id @default(cuid())
  pendingRequestId      String
  approverSlackUserId   String
  approverSlackUserName String
  justification         String?
  decision              String         // "APPROVED" | "DENIED"
  decidedAt             DateTime       @default(now())

  pendingRequest        PendingRequest @relation(fields: [pendingRequestId], references: [id], onDelete: Cascade)

  // One approver gets one vote per pending request — second click is a no-op.
  @@unique([pendingRequestId, approverSlackUserId])
  @@index([pendingRequestId])
}

// API keys for authenticating callers as a specific Organization.
// The plaintext key is shown to the user exactly once at mint time.
model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String       // human label, e.g. "ci-server", "dashboard"
  prefix         String       @unique // first 8 chars of plaintext, used for fast lookup
  hash           String       // scrypt hash of the full plaintext key
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs      AuditLog[]

  @@index([organizationId])
}

// Stored OpenAPI Specs
model OpenApiSpec {
  id             String       @id @default(cuid())
  organizationId String
  url            String
  rawJson        Json
  internalCount  Int
  externalCount  Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// Dynamic Policy Execution Rules
model PolicyRule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String
  ruleType       String       // "ALLOWLIST" | "BLOCK" | "AUDIT" | "RATE_LIMIT" | "MUTATION_APPROVAL"
  targetMethod   String       // "POST", "PUT", "*"
  targetPath     String       // "/v1/refunds", "/v1/users/:id", "/v1/foo/*", "*"
  action         String       // "BLOCK", "SLACK_APPROVAL", "REQUIRE_HEADER", "ALLOW", "RATE_LIMIT"
  actionConfig   Json         // e.g. {"channel":"#finance-ops"} | {"limit":100,"windowMs":60000,"scope":"agent+tenant"}
  priority       Int          @default(100)  // lower = evaluated first
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@index([organizationId, priority])
}

// Authorized Agents — identities the proxy recognizes via x-agent-id header.
// Org-level ApiKey auth still applies; the agent identity is an additional
// caller assertion that scopes the call to a known, revocable principal.
model AgentIdentity {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  source         String       // "internal_mcp" | "external_mcp"
  tenantScope    String?      // when set, x-tenant-id must match
  enabled        Boolean      @default(true)
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           AuditLog[]

  @@index([organizationId])
}

// Tamper-evident execution ledger. Each row's `hash` is sha256 of its canonical
// fields plus the previous row's `hash`, forming a per-organization chain.
// See src/audit/canonical.util.ts and AuditService.
model AuditLog {
  id             String        @id @default(cuid())
  organizationId String
  seq            Int           // monotonic per organization
  agentId        String?
  apiKeyId       String?
  method         String
  path           String
  source         String        // "internal_mcp" | "external_mcp" | "system"
  tenantId       String?
  reasoning      String?       // x-agent-reasoning header value
  reason         String?       // policy reason or error message
  actionTaken    String        // "EXECUTED" | "BLOCKED" | "AWAITING_APPROVAL" | "INCOMPLETE"
  upstreamStatus Int?          // null when no upstream call was made
  requestBytes   Int           @default(0)
  responseBytes  Int?
  latencyMs      Float
  // Score in [0, 1] from BEHAVIORAL_ANOMALY rule, when one was active. Stored
  // as metadata only — deliberately NOT part of the audit hash (it's derived
  // data, and including it would break chain compatibility with rows written
  // before this feature shipped). Tamper with this field and the chain still
  // verifies; tamper with method/path/etc and it doesn't.
  anomalyScore   Float?
  prevHash       String        // hash of previous row, "genesis" for first
  hash           String        // sha256 of canonical(this row)
  timestamp      DateTime      @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent          AgentIdentity? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  apiKey         ApiKey?        @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@unique([organizationId, seq])
  @@index([organizationId, timestamp])
  @@index([organizationId, path])
}
